[Unit]
Description=MTS GPTHub stack (docker compose)
Documentation=https://github.com/irwkc/mts
After=docker.service network-online.target
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/ubuntuuser/mts
# Читается .env из WorkingDirectory
ExecStart=/usr/bin/docker compose up -d --remove-orphans
ExecStop=/usr/bin/docker compose stop
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
