# Скопируйте в репозиторий: .github/workflows/gpthub-pytest.yml
# Push workflow в GitHub требует PAT с правом «workflow» (или добавьте файл вручную в веб-интерфейсе).

name: gpthub-gateway tests

on:
  push:
    branches: [main]
    paths:
      - "gpthub-gateway/**"
      - ".github/workflows/gpthub-pytest.yml"
  pull_request:
    paths:
      - "gpthub-gateway/**"
      - ".github/workflows/gpthub-pytest.yml"

jobs:
  pytest:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: gpthub-gateway
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt -r requirements-dev.txt

      - name: Run pytest
        run: python -m pytest tests/ -q --tb=short
