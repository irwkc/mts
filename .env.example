# Скопируйте в .env и подставьте ключ MWS GPT (не коммитьте .env).

MWS_API_KEY=sk-your-key-here

# База API (по умолчанию публичный endpoint из документации MWS GPT)
MWS_API_BASE=https://api.gpt.mws.ru/v1

# Идентификаторы моделей — приведите к списку GET /v1/models для вашего ключа.
# У ключа «команда» часто ограниченный каталог (без mts-anya и т.п.) — см. docs/MWS_TEAM_MODELS.md
DEFAULT_LLM=llama-3.1-8b-instruct
VISION_MODEL=cotype-pro-vl-32b
IMAGE_GEN_MODEL=qwen-image
# Для MWS уточните по GET /v1/models; whisper-large-v3 может быть недоступен команде — тогда whisper-medium или whisper-turbo-local
ASR_MODEL=whisper-medium
# Язык для Whisper при прокси /v1/audio/transcriptions: пусто = авто (удобно для English); ru = стабильнее для русской речи
# GPTHUB_ASR_DEFAULT_LANGUAGE=
# GPTHUB_ASR_DEFAULT_LANGUAGE=ru
EMBEDDING_MODEL=bge-m3

WEBUI_SECRET_KEY=change-me-to-a-long-random-string

# Авто-админ при первом запуске (пустой volume open-webui-data). Если пользователи уже есть — не сработает.
WEBUI_ADMIN_EMAIL=test@mail.ru
WEBUI_ADMIN_PASSWORD=123
WEBUI_ADMIN_NAME=Test

ENABLE_SIGNUP=true

# Роль новых пользователей: pending (нужна активация админом) | user | admin
DEFAULT_USER_ROLE=user

# Вход в WebUI: true (обычно). false — вообще без логина, но только если ещё нет пользователей в БД;
# иначе Open WebUI откажет. Сброс: удалить том open-webui-data (потеря чатов) и поднять заново.
# WEBUI_AUTH=false

# Публичный URL веб-интерфейса (за nginx с HTTPS укажите https://… — см. deploy/nginx-open-webui-https.example.conf)
WEBUI_URL=http://localhost:3000

# Брендинг Open WebUI (заголовок, часть подписей в UI)
# WEBUI_NAME=BAOBAB productions

# Имя авто-модели в списке моделей (шлюз GET /v1/models)
# GPTHUB_AUTO_MODEL_DISPLAY_NAME=gena 2.0
# Кто такой ассистент (подмешивается в system; пустое значение отключает)
# GPTHUB_GENA_IDENTITY=

# Образ UI с темой BAOBAB (сборка: ./open-webui-baobab). CI пушит в GHCR.
# OPENWEBUI_IMAGE=ghcr.io/irwkc/mts-open-webui-baobab:latest

# Голос / диктовка: микрофон в Chrome/Edge только на https:// или http://localhost (не http:// с IP/домена без TLS).
# В docker-compose у open-webui задано ENABLE_PERSISTENT_CONFIG=false, чтобы STT/TTS из env не перезаписывались SQLite.
# TTS (если MWS ожидает другие имена — см. документацию провайдера):
# AUDIO_TTS_MODEL=tts-1
# AUDIO_TTS_VOICE=alloy

# Образ шлюза из GitHub Actions (по умолчанию GHCR; локально: docker compose build)
# GPTHUB_IMAGE=ghcr.io/irwkc/mts-gpthub-gateway:latest

# Префикс [GPTHub route: …] в system-сообщениях (демо). false — отключить.
# GPTHUB_ROUTER_DEBUG=true

# Режим авто-роутинга: gena (как gena/router: перехваты + select_model), llm (нейро-роутер), legacy (старые правила шлюза).
# GPTHUB_ROUTER_MODE=gena
# Модель «обычного чата» в ветке gena:chat (аналог mws-gpt-alpha; пусто = DEFAULT_LLM).
# GPTHUB_GENA_CHAT_MODEL=mws-gpt-alpha
# ChromaDB (как gena/router/memory) + ссылки на сгенерированные PPTX в /static/
# CHROMA_HOST=chroma
# CHROMA_PORT=8000
# Публичный URL шлюза для ссылок на картинки/PPTX в чате (markdown ![](...)).
# Локально в compose по умолчанию http://127.0.0.1:8081 — иначе браузер на :3000 не найдёт /static/.
# За nginx с тем же доменом, что и UI, можно оставить пустым и положиться на относительные пути или задать https://ваш-домен
# GPTHUB_PUBLIC_BASE_URL=https://ваш-домен
# GPTHUB_PUBLIC_BASE_URL=http://127.0.0.1:8081
# GPTHUB_GENA_CODE_MODEL=qwen3-coder-480b-a35b
# GPTHUB_GENA_LONG_DOC_MODEL=cotype-pro-vl-32b
# GPTHUB_GENA_LONG_DOC_WORDS=600
# Повторы к MWS при 429/5xx/таймауте (итого попыток = 1 + retries)
# GPTHUB_MWS_HTTP_RETRIES=2
# GPTHUB_MWS_RETRY_BACKOFF_SEC=1.0
# Кэш результатов DuckDuckGo text search (секунды, число записей)
# GPTHUB_WEB_SEARCH_CACHE_TTL_SEC=120
# GPTHUB_WEB_SEARCH_CACHE_MAX_ENTRIES=64
# Лимит размера JSON тела chat/completions (символов)
# GPTHUB_MAX_CHAT_PAYLOAD_CHARS=500000
# Максимум слайдов в одной презентации gena
# GPTHUB_MAX_PRESENTATION_SLIDES=20
# PPTX: кастомный шаблон; bundled keynote_base.pptx; валидация ZIP; round-trip (часто ломает Keynote — по умолчанию false); лимит стороны картинки
# GPTHUB_PPTX_TEMPLATE_PATH=
# GPTHUB_PPTX_USE_BUNDLED_TEMPLATE=false
# GPTHUB_PPTX_ROUNDTRIP=false
# GPTHUB_PPTX_VALIDATE_ZIP=true
# GPTHUB_PPTX_MAX_IMAGE_PX=4096

# Память шлюза (gena): извлечение фактов LLM + SQLite на volume gpthub-data
# GPTHUB_MEMORY_LLM_DIGEST=true
# GPTHUB_MEMORY_DIGEST_MODEL=llama-3.1-8b-instruct
# GPTHUB_MEMORY_RAW_FALLBACK=false
# GPTHUB_MEMORY_MAX_ITEMS=400
# Релевантных фрагментов в промпт (семантический поиск)
# MEMORY_TOP_K=8
# Длинные чаты: сводка «головы» диалога (доп. вызов LLM на каждый запрос при длинной истории)
# GPTHUB_MEMORY_COMPRESS_CONTEXT=false
# GPTHUB_MEMORY_COMPRESS_AFTER=36
# GPTHUB_MEMORY_COMPRESS_KEEP=16

# --- Логи (в docker-compose по умолчанию DEBUG для шлюза и Open WebUI backend) ---
# GPTHUB_LOG_LEVEL=DEBUG
# Санитизированный JSON тел chat в логах (входящий запрос + то, что уходит в MWS); 0 = только строка-сводка без тела
# GPTHUB_LOG_JSON_MAX_CHARS=16000
# Размер текста ответа MWS при ошибке (4xx/5xx) в логах gpthub.mws
# GPTHUB_LOG_UPSTREAM_ERROR_CHARS=8000
# GLOBAL_LOG_LEVEL=DEBUG

# --- Если в интерфейсе «No models» / пропали модели ---
# На сервере: docker compose ps; docker compose logs gpthub-gateway --tail=100; docker compose logs open-webui --tail=80
# С хоста: curl -sS -H "Authorization: Bearer ВАШ_MWS_API_KEY" http://127.0.0.1:8081/v1/models | head -c 2000
# Убедитесь, что в .env задан корректный MWS_API_KEY и что шлюз видит MWS_API_BASE (сеть/DNS).
# В WebUI: Settings → Connections: OpenAI API включён; URL совпадает с OPENAI_API_BASE_URL в compose (через Docker сеть это http://gpthub-gateway:8080/v1).
